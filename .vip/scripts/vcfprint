#!/usr/bin/env python3

import quopri
from prettytable import PrettyTable

def decode_value(value):
    try:
        if "=" in value:
            return quopri.decodestring(value).decode("utf-8", errors="replace")
        return value
    except:
        return value

def parse_vcf(file_path):
    contacts = []
    contact = {}
    inside_photo = False

    with open(file_path, "r", encoding="utf-8", errors="replace") as file:
        for raw_line in file:
            line = raw_line.rstrip("\n")

            # If we're inside a PHOTO block, skip continuation lines
            if inside_photo:
                if line.startswith((" ", "\t")):
                    continue
                else:
                    inside_photo = False

            if line == "BEGIN:VCARD":
                contact = {}

            elif line.startswith("FN"):
                value = line.split(":", 1)[1]
                contact["Name"] = decode_value(value)

            elif line.startswith("N") and "Name" not in contact:
                value = line.split(":", 1)[1]
                parts = value.split(";")
                contact["Name"] = decode_value(" ".join(filter(None, reversed(parts))))

            elif line.startswith("TEL"):
                contact["Phone"] = line.split(":", 1)[1]

            elif line.startswith("EMAIL"):
                contact["Email"] = line.split(":", 1)[1]

            elif line.startswith("PHOTO"):
                contact["Image"] = "Yes"
                inside_photo = True

            elif line == "END:VCARD":
                contacts.append(contact)

    return contacts


def display_contacts(contacts):
    table = PrettyTable()
    table.field_names = ["Name", "Phone", "Email", "Image"]

    for contact in contacts:
        table.add_row([
            contact.get("Name", "N/A"),
            contact.get("Phone", "N/A"),
            contact.get("Email", "N/A"),
            contact.get("Image", "No")
        ])

    print(table)


if __name__ == "__main__":
    contacts = parse_vcf("Contacts.vcf")
    display_contacts(contacts)
