#!/usr/bin/env python3

import quopri
from prettytable import PrettyTable

def decode_value(value):
    """Decode quoted-printable UTF-8 values if needed."""
    try:
        if "=" in value:
            return quopri.decodestring(value).decode("utf-8", errors="replace")
        return value
    except:
        return value

def unfold_lines(lines):
    """Merge folded vCard lines (lines starting with space/tab)."""
    unfolded = []
    for line in lines:
        if line.startswith((" ", "\t")) and unfolded:
            unfolded[-1] += line.strip()
        else:
            unfolded.append(line.strip())
    return unfolded

def parse_vcf(file_path):
    contacts = []
    contact = {}

    with open(file_path, "r", encoding="utf-8", errors="replace") as file:
        lines = unfold_lines(file.readlines())

    for line in lines:
        if line == "BEGIN:VCARD":
            contact = {}

        elif line.startswith("FN"):
            value = line.split(":", 1)[1]
            contact["Name"] = decode_value(value)

        elif line.startswith("N"):
            if "Name" not in contact:
                value = line.split(":", 1)[1]
                parts = value.split(";")
                contact["Name"] = decode_value(" ".join(filter(None, reversed(parts))))

        elif line.startswith("TEL"):
            value = line.split(":", 1)[1]
            contact["Phone"] = decode_value(value)

        elif line.startswith("EMAIL"):
            value = line.split(":", 1)[1]
            contact["Email"] = decode_value(value)

        elif line == "END:VCARD":
            contacts.append(contact)

    return contacts

def display_contacts(contacts):
    table = PrettyTable()
    table.field_names = ["Name", "Phone", "Email"]

    for contact in contacts:
        table.add_row([
            contact.get("Name", "N/A"),
            contact.get("Phone", "N/A"),
            contact.get("Email", "N/A")
        ])

    print(table)

if __name__ == "__main__":
    contacts = parse_vcf("Contacts.vcf")
    display_contacts(contacts)
