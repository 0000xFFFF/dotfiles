#!/usr/bin/env python3

import quopri
from prettytable import PrettyTable

def decode_value(value):
    try:
        if "=" in value:
            return quopri.decodestring(value).decode("utf-8", errors="replace")
        return value
    except:
        return value

def unfold_vcf_lines(lines):
    """Join folded vCard lines."""
    unfolded = []
    for line in lines:
        line = line.rstrip("\n")

        # Continuation of previous line
        if line.startswith((" ", "\t")) and unfolded:
            unfolded[-1] += line[1:]
        else:
            unfolded.append(line)

    return unfolded

def parse_vcf(file_path):
    contacts = []

    with open(file_path, "r", encoding="utf-8", errors="replace") as f:
        lines = unfold_vcf_lines(f.readlines())

    contact = {}

    for line in lines:
        if line == "BEGIN:VCARD":
            contact = {}

        elif line.startswith("FN"):
            contact["Name"] = decode_value(line.split(":", 1)[1])

        elif line.startswith("N") and "Name" not in contact:
            parts = line.split(":", 1)[1].split(";")
            contact["Name"] = decode_value(" ".join(filter(None, reversed(parts))))

        elif line.startswith("TEL"):
            contact["Phone"] = line.split(":", 1)[1]

        elif line.startswith("EMAIL"):
            contact["Email"] = line.split(":", 1)[1]

        elif line.startswith("PHOTO"):
            contact["Image"] = "Yes"
            # Ignore actual image data

        elif line == "END:VCARD":
            contacts.append(contact)

    return contacts

def display_contacts(contacts):
    table = PrettyTable()
    table.field_names = ["Name", "Phone", "Email", "Image"]

    for c in contacts:
        table.add_row([
            c.get("Name", "N/A"),
            c.get("Phone", "N/A"),
            c.get("Email", "N/A"),
            c.get("Image", "No")
        ])

    print(table)

if __name__ == "__main__":
    contacts = parse_vcf("Contacts.vcf")
    display_contacts(contacts)
